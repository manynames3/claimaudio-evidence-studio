# Local demo remains runnable with no environment variables.
# Set these only when moving from mock mode to the Neon + AWS paid-pilot path.

CLAIMAUDIO_BACKEND_MODE=neon-aws

# Pilot auth
# Local fallback adjuster code is demo-pilot. Set real role-specific values before any external pilot.
CLAIMAUDIO_REQUIRE_AUTH=true
CLAIMAUDIO_PILOT_ACCESS_CODE=
CLAIMAUDIO_SUPERVISOR_ACCESS_CODE=
CLAIMAUDIO_ADMIN_ACCESS_CODE=
CLAIMAUDIO_SESSION_SECRET=

# Neon Postgres free tier
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=verify-full
CLAIMAUDIO_TENANT_ID=11111111-1111-4111-8111-111111111111

# AWS service region
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_KMS_KEY_ARN=

# Encrypted object storage
AWS_S3_AUDIO_BUCKET=claimaudio-pilot-audio
AWS_S3_EXPORT_BUCKET=claimaudio-pilot-exports

# Async processing
AWS_SQS_PROCESSING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/claimaudio-processing
AWS_STEP_FUNCTIONS_STATE_MACHINE_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:claimaudio-evidence-processing

# AI analysis
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
