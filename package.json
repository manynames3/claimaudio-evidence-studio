{
  "name": "claimaudio-evidence-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "db:migrate": "tsx -r tsconfig-paths/register scripts/apply-neon-migration.ts",
    "db:seed": "tsx -r tsconfig-paths/register scripts/seed-neon-demo-data.ts",
    "test:guardrails": "tsx -r tsconfig-paths/register scripts/validate-ai-guardrails.ts",
    "test": "npm run typecheck && npm run test:guardrails"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1059.0",
    "@aws-sdk/client-s3": "^3.1059.0",
    "@aws-sdk/client-sfn": "^3.1059.0",
    "@aws-sdk/client-sqs": "^3.1059.0",
    "@aws-sdk/client-transcribe": "^3.1059.0",
    "@aws-sdk/s3-request-presigner": "^3.1059.0",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.4",
    "pg": "^8.21.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "wrangler": "^4.97.0"
  }
}
